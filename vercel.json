{
  "buildCommand": "cd frontend && npm install && CI=false npm run build",
  "outputDirectory": "frontend/build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://e-voting-backend.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://e-voting-backend.onrender.com/auth/:path*"
    },
    {
      "source": "/health",
      "destination": "https://e-voting-backend.onrender.com/health"
    },
    {
      "source": "/docs",
      "destination": "https://e-voting-backend.onrender.com/docs"
    },
    {
      "source": "/openapi.json",
      "destination": "https://e-voting-backend.onrender.com/openapi.json"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
